VITE_TEST_MODE=true

# Stub Firebase credentials — non-empty so Vite doesn't error on undefined env vars.
# These are never used in test mode because FirestoreYjsProvider and WebRTC are skipped.
VITE_FIREBASE_API_KEY=test-api-key-placeholder
VITE_FIREBASE_AUTH_DOMAIN=test-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=test-project
VITE_FIREBASE_STORAGE_BUCKET=test-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:testappidplaceholder
