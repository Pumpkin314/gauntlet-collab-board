# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these from Firebase Console > Project Settings > Your apps > SDK setup and configuration

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# WebRTC Signaling Server (optional)
# Defaults to ws://localhost:4445 (dev only). Set for production:
#   Public y-webrtc server (no-setup, good for testing):
#     VITE_SIGNALING_SERVERS=wss://y-webrtc-ckynwnzncc-ey.a.run.app
#   Self-hosted on Render (recommended for sharing):
#     VITE_SIGNALING_SERVERS=wss://your-app.onrender.com
#   Fly.io (this project):
#     VITE_SIGNALING_SERVERS=wss://g4-collab-board.fly.dev
# Comma-separate multiple servers for redundancy.
VITE_SIGNALING_SERVERS=

# Optional: ICE servers for WebRTC datachannel connectivity.
# Format is JSON array (must be valid JSON, not JS):
#   VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# For stricter NAT/firewalls, add TURN (example):
#   VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.yourdomain.com:3478","username":"user","credential":"pass"}]
VITE_ICE_SERVERS=

# Optional ICE transport policy:
#   all   = try direct ICE candidates + relay (default browser behavior)
#   relay = force TURN relay only (useful to verify TURN works)
VITE_ICE_TRANSPORT_POLICY=

# Anthropic API Key (dev-only, used by Boardie AI agent)
# Get from https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# Langfuse Observability (optional — agent pipeline traces)
# Get from https://cloud.langfuse.com → Settings → API Keys
VITE_LANGFUSE_PUBLIC_KEY=
VITE_LANGFUSE_SECRET_KEY=
VITE_LANGFUSE_HOST=https://cloud.langfuse.com
