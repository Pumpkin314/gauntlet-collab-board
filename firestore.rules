rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the caller is the board owner
    function isOwner(boardId) {
      return request.auth != null
        && get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId == request.auth.uid;
    }

    // Helper: check if the caller has a share entry on the board
    function getShareRole(boardId) {
      return get(/databases/$(database)/documents/boards/$(boardId)).data.sharedWith[request.auth.uid].role;
    }

    function isShared(boardId) {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.sharedWithUids;
    }

    function isEditor(boardId) {
      return isShared(boardId) && getShareRole(boardId) == 'editor';
    }

    function isViewer(boardId) {
      return isShared(boardId) && getShareRole(boardId) == 'viewer';
    }

    // Board documents
    match /boards/{boardId} {
      // Owner: full CRUD
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isShared(boardId)
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || (isEditor(boardId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['sharedWith', 'sharedWithUids', 'ownerId']))
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Board subcollections: objects
      match /objects/{objectId} {
        allow read: if request.auth != null && (isOwner(boardId) || isShared(boardId));
        allow write: if request.auth != null && (isOwner(boardId) || isEditor(boardId));
      }

      // Board subcollections: presence
      match /presence/{userId} {
        allow read: if request.auth != null && (isOwner(boardId) || isShared(boardId));
        allow write: if request.auth != null && (isOwner(boardId) || isShared(boardId));
      }
    }

    // Users collection: anyone authenticated can read (for email lookup), self-only write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
