rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the parent board document
    function boardDoc(boardId) {
      return get(/databases/$(database)/documents/boards/$(boardId)).data;
    }

    function isOwner(boardId) {
      return request.auth != null && boardDoc(boardId).ownerId == request.auth.uid;
    }

    function isEditor(boardId) {
      return request.auth != null
        && request.auth.uid in boardDoc(boardId).sharedWithUids
        && boardDoc(boardId).sharedWith[request.auth.uid].role == 'editor';
    }

    function isViewer(boardId) {
      return request.auth != null
        && request.auth.uid in boardDoc(boardId).sharedWithUids
        && boardDoc(boardId).sharedWith[request.auth.uid].role == 'viewer';
    }

    function hasAnyAccess(boardId) {
      return isOwner(boardId) || isEditor(boardId) || isViewer(boardId);
    }

    // Board documents
    match /boards/{boardId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid
        || request.auth.uid in resource.data.sharedWithUids
      );
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        // Owner can update anything
        resource.data.ownerId == request.auth.uid
        // Editors can update but NOT change sharing fields or ownership
        || (isEditor(boardId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['sharedWith', 'sharedWithUids', 'ownerId', 'ownerName']))
      );
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Board subcollections (objects, presence) inherit access from parent board
      match /objects/{objectId} {
        allow read: if hasAnyAccess(boardId);
        allow write: if isOwner(boardId) || isEditor(boardId);
      }

      match /presence/{presenceId} {
        allow read: if hasAnyAccess(boardId);
        allow write: if request.auth != null && hasAnyAccess(boardId);
      }
    }

    // User profiles for email-based lookup
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
